# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# Dependencies and package-manager state
node_modules/
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# Test, framework, and build output
/coverage
/.next/
/out/
build/
dist/
*.tsbuildinfo
next-env.d.ts

# Environment files and credentials
.env*
!.env.example
*.pem
*.key

# Logs and local runtime data
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*
*.db*
*.jsonl
*.sqlite*
memory.json

# Vercel
.vercel

# Local development tools and generated artifacts
.DS_Store
*.code-workspace
.claude/
.codex/
__pycache__/
*.py[cod]
.venv/
venv/
.pytest_cache/
.mypy_cache/
.ruff_cache/
*.gguf
*.safetensors

# Local-only workspace material and snapshots
FEATURES.md
/MEMORY.md
/memory_summary.md
/local-only/
/.openclaw/sandbox-skills/
/media/inbound/
backup_*/
backups/
*_backup/
migration-backups/
