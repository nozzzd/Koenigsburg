# ─── Königsburg Web Portal — environment variables ──────────────────────────
# Copy to `.env.local` for local dev and fill in real values.
# NEVER commit real values: `.env.local` is gitignored; in production these
# live in Vercel → Project → Settings → Environment Variables.

# Public site URL (no trailing slash). Local: http://localhost:3000
# Production: your Vercel domain, e.g. https://koenigsburg.vercel.app
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Supabase → Project Settings → Data API
SUPABASE_URL=https://your-project-ref.supabase.co
# Supabase → Project Settings → API Keys → service_role (SECRET — server only)
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# Any long random string; sign-in cookies are HMAC-signed with it.
# Generate one:  node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
SESSION_SECRET=your-random-64-char-secret-here

# Discord Developer Portal → your application → OAuth2
DISCORD_CLIENT_ID=your-discord-app-client-id
DISCORD_CLIENT_SECRET=your-discord-app-client-secret
# Discord Developer Portal → General Information → Public Key
# Verifies that /verify slash-command requests really come from Discord.
DISCORD_PUBLIC_KEY=your-discord-app-public-key
# Discord Developer Portal → your application → Bot → Token
DISCORD_BOT_TOKEN=your-bot-token-here
# Right-click your server icon → Copy Server ID (Developer Mode required)
DISCORD_GUILD_ID=your-server-id
# Server Settings → Roles → right-click @Citizen → Copy Role ID
DISCORD_CITIZEN_ROLE_ID=your-citizen-role-id

# Protects the daily cron endpoint (/api/cron/verify-reminders). Set the SAME
# value in Vercel and Vercel Cron sends it automatically as a Bearer token.
# Generate one:  node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
CRON_SECRET=your-random-cron-secret-here

# QMSync v1 receiver (/api/handshake and /api/sync).
# Set this to the exact server ID shown by the mod's /qmsync status command.
# NOTE: this is a public, guessable value - it is NOT authentication on its own.
QMSYNC_SERVER_ID=multiplayer/play_example_com
# Optional friendly label shown on /inventory.
QMSYNC_SERVER_NAME=Koenigsburg
# SHARED SECRET that authenticates the mod to the sync endpoints. Must match
# the QMSync mod's own QMSYNC_API_KEY. When set, every /api/handshake,
# /api/sync and /api/inventory/sync request MUST carry this key (sent as
# Authorization: Bearer, an x-api-key header, or an apiKey body field - all
# accepted); requests without it get 401.
# Leave BLANK to keep the old serverId-only behaviour during rollout, then set
# it here once the mod is sending the key.
# Generate one:  node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
QMSYNC_API_KEY=your-random-qmsync-secret-here

# ─── Rate limiting (optional but recommended) ───────────────────────────────
# Durable, cross-instance rate limits for login, signup, analytics, map uploads
# and the QMSync endpoints. Create a free database at https://console.upstash.com
# (Redis) and copy its REST URL + token. If these are BLANK the app falls back
# to a weaker per-instance in-memory limiter, so nothing breaks without them.
UPSTASH_REDIS_REST_URL=https://your-db.upstash.io
UPSTASH_REDIS_REST_TOKEN=your-upstash-rest-token
